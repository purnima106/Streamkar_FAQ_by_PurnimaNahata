# pyenv
#   For a library or binary, you wish to ignore these files, but for an app, they can be useful.
# .python-version

# pipenv
#   According to pypa/pipenv#1181, it is recommended to include Pipfile.lock in version control.
#   However, in case you'd like to ignore it, uncomment the following line:
# .Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# pdm.lock
#   pdm-specific folder
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/frenzy-peng/pdm
__pypackages__/

